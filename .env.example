# WishLive local infrastructure
# Copy to .env for local development. Do not commit real secrets.

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=wishlive
POSTGRES_PASSWORD=wishlive_dev
POSTGRES_DB=wishlive
DATABASE_URL=postgresql://wishlive:wishlive_dev@localhost:5432/wishlive

# Redis Streams
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Hardhat Localnet
HARDHAT_HOST=localhost
HARDHAT_PORT=8545
HARDHAT_RPC_URL=http://localhost:8545
HARDHAT_CHAIN_ID=31337
# Public default Hardhat account only. Do not use on real networks.
DEV_WALLET_ADDRESS=0xf39fd6e51aad88f6f4ce6ab8827279cfffb92266

# Future application service ports
FRONTEND_PORT=3000
REGISTRY_PORT=3001
SETTLEMENT_PORT=3003
CONCIERGE_PORT=3004

# ai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# contracts
AGENT_PROFILE_ADDRESS=
ESCROW_ADDRESS=
TICKET_NFT_ADDRESS=
